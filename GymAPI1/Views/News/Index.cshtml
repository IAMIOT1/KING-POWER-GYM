<section id="News" class="news-banner">
    <h1>TIN TỨC</h1>
</section>

<div class="news-filter">

    <<div class="news-category">

        <span class="tab active" onclick="filterNews(this,'all')">TẤT CẢ</span>
        <span class="tab" onclick="filterNews(this,'story')">CÂU CHUYỆN CITIGYM</span>
        <span class="tab" onclick="filterNews(this,'training')">TIN TẬP LUYỆN</span>
        <span class="tab" onclick="filterNews(this,'promo')">KHUYẾN MÃI</span>
        <span class="tab" onclick="filterNews(this,'nutrition')">DINH DƯỠNG</span>

    </div>

    <script>

            function filterNews(element,category){

            // đổi màu tab
            let tabs = document.querySelectorAll(".tab");
            tabs.forEach(t => t.classList.remove("active"));
            element.classList.add("active");

            // lọc bài viết
            let posts = document.querySelectorAll(".news-card");

            posts.forEach(post => {

            if(category === "all"){
            post.style.display="block";
            }
            else if(post.classList.contains(category)){
            post.style.display="block";
            }
            else{
            post.style.display="none";
            }

            });

            }

    </script>
    <div class="search-box">

        <input type="text" placeholder="Tìm kiếm...">

    </div>

</div>

