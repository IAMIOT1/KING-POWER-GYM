    <!-- Form đăng ký tham gia-->
    <section class="club-visit">

        <div class="visit-overlay">

            <h2>ĐĂNG KÝ THAM QUAN CÂU LẠC BỘ</h2>

            <form class="visit-form">

                <div class="row">
                    <input type="text" placeholder="Họ và tên">
                    <input type="text" placeholder="Số điện thoại">
                </div>

                <select>
                    <option>Câu lạc bộ bạn muốn tham gia</option>
                <option>KING POWER GYM Thành Thái</option>
                <option>KING POWER GYM Điện Biên Phủ</option>
                <option>KING POWER GYM Phổ Quang</option>
                </select>

                <select>
                    <option>Giờ nào chúng tôi có thể gọi bạn?</option>
                    <option>Sáng</option>
                    <option>Chiều</option>
                    <option>Tối</option>
                </select>

                <button type="submit">ĐĂNG KÝ NGAY</button>

            </form>

        </div>

    </section>
    <script>

        function calculateBMI(){

        let height = document.getElementById("height").value;
        let weight = document.getElementById("weight").value;

        height = height / 100;

        let bmi = weight / (height * height);

        bmi = bmi.toFixed(1);

        let result = "";

        if(bmi < 18.5){
        result = "Thiếu cân";
        }
        else if(bmi < 24.9){
        result = "Bình thường";
        }
        else if(bmi < 29.9){
        result = "Thừa cân";
        }
        else{
        result = "Béo phì";
        }

        document.getElementById("result").innerHTML =
        "Chỉ số BMI của bạn: " + bmi + " (" + result + ")";

        }

    </script>
<script>

    const slider = document.getElementById("slider")
    const mask = document.getElementById("mask")
    const container = document.querySelector(".compare-container")

    let isDragging = false

    slider.addEventListener("mousedown", () => isDragging = true)

    window.addEventListener("mouseup", () => isDragging = false)

    /* QUAN TRỌNG: vẫn bắt khi ra ngoài */
    window.addEventListener("mousemove", (e) => {

        if(!isDragging) return

        const rect = container.getBoundingClientRect()

        let x = e.clientX - rect.left

        /* FIX kẹt mép */
        if(x < 0) x = 0
        if(x > rect.width) x = rect.width

        mask.style.width = x + "px"
        slider.style.left = x + "px"

    })
</script>