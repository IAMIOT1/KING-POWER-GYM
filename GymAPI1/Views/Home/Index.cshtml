        <div class="slider-dots">

            <span class="dot active"></span>
            <span class="dot"></span>
            <span class="dot"></span>
            <span class="dot"></span>
            <span class="dot"></span>

        </div>
    </section>

    <script>

        let position = 0;
        let index = 0;

        const move = 320;

        const grid = document.getElementById("storyGrid");
        const dots = document.querySelectorAll(".dot");

        function updateDots(){

        dots.forEach(dot => dot.classList.remove("active"));

        dots[index].classList.add("active");

        }

        function nextStory(){

        position -= move;
        index++;

        if(index >= dots.length){
        index = 0;
        position = 0;
        }

        grid.style.transform = "translateX("+position+"px)";

        updateDots();

        }

        function prevStory(){

        position += move;
        index--;

        if(index < 0){
        index = dots.length - 1;
        position = -(move*(dots.length-1));
        }

        grid.style.transform = "translateX("+position+"px)";

        updateDots();

        }

    </script>
