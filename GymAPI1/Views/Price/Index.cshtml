<section class="price-section">
    <div class="container">
        <div class="row align-items-center">

            <!-- LEFT -->
            <div class="col-md-6">

                <!-- MENU -->
                <div class="package-menu">
                    <span class="tab active" onclick="changePackage(this,'classic')">CLASSIC</span>
                    <span class="tab" onclick="changePackage(this,'classicplus')">CLASSIC-PLUS</span>
                    <span class="tab" onclick="changePackage(this,'passport')">KING POWER GYM PASSPORT</span>
                    <span class="tab" onclick="changePackage(this,'royal')">KING POWER GYM ROYAL</span>
                    <span class="tab" onclick="changePackage(this,'premium')">KING POWER GYM PREMIUM</span>
                    <span class="tab" onclick="changePackage(this,'signature')">SIGNATURE</span>
                </div>

                <!-- WRAP -->
                <div class="duration-wrapper">

                    <!-- LỊCH -->
                    <div class="duration-grid">
                        <div class="duration big active" onclick="changeDuration(this,24)">24<br><span>THÁNG</span></div>
                        <div class="duration" onclick="changeDuration(this,12)">12<br><span>THÁNG</span></div>
                        <div class="duration" onclick="changeDuration(this,6)">6<br><span>THÁNG</span></div>
                        <div class="duration" onclick="changeDuration(this,3)">3<br><span>THÁNG</span></div>
                        <div class="duration full" onclick="changeDuration(this,1)">1<br><span>THÁNG</span></div>
                    </div>

                    <!-- LINE -->
                    <div class="line"></div>

                    <!-- GIÁ -->
                    <div class="price-detail">
                        <p>Thời gian: <b id="duration">24 THÁNG</b></p>
                        <p>Tổng: <b id="total">15,370,000 VND</b></p>
                        <p>Tháng: <b id="month">640,417 VND</b></p>
                        <p>Ngày: <b id="day">21,347 VND</b></p>
                    </div>

                </div>
            </div>

            <!-- RIGHT -->
            <div class="col-md-6 text-center">
                <img src="/images/chay.png" class="img-fluid img-box">
            </div>

        </div>
    </div>
</section>
<script>

    const packages = {

    classic:{
    total:"15,370,000 VND",
    month:"640,417 VND",
    day:"21,347 VND"
    },

    classicplus:{
    total:"18,440,000 VND",
    month:"768,333 VND",
    day:"25,611 VND"
    },

    passport:{
    total:"19,970,000 VND",
    month:"832,083 VND",
    day:"27,736 VND"
    },

    royal:{
    total:"23,060,000 VND",
    month:"960,833 VND",
    day:"32,028 VND"
    },

    premium:{
    total:"19,970,000 VND",
    month:"832,083 VND",
    day:"27,736 VND"
    },

    signature:{
    total:"86,550,000 VND",
    month:"3,606,250 VND",
    day:"120,208 VND"
    }

    };


    function changePackage(element,name){

    // đổi màu tab
    let tabs = document.querySelectorAll(".tab");

    tabs.forEach(t => t.classList.remove("active"));

    element.classList.add("active");


    // đổi giá
    document.getElementById("total").innerText = packages[name].total;
    document.getElementById("month").innerText = packages[name].month;
    document.getElementById("day").innerText = packages[name].day;

    }

</script>



<script>

    document.addEventListener("DOMContentLoaded", function(){

    let currentPackage = "classic";
    let currentDuration = 24;

    const packages = {
        classic: { total:15370000 },
        classicplus: { total:18440000 },
        passport: { total:19970000 },
        royal: { total:23060000 },
        premium: { total:19970000 },
        signature: { total:86550000 }
    };

    // CLICK GÓI
    document.querySelectorAll('.tab').forEach(tab => {
        tab.addEventListener('click', function(){

            document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
            this.classList.add('active');

            currentPackage = this.getAttribute("onclick").match(/'(.*?)'/)[1];
            updatePrice();
        });
    });

    // CLICK THÁNG
    document.querySelectorAll('.duration').forEach(d => {
        d.addEventListener('click', function(){

            document.querySelectorAll('.duration').forEach(x => x.classList.remove('active'));
            this.classList.add('active');

            currentDuration = parseInt(this.innerText);
            updatePrice();
        });
    });

    // FORMAT
    function format(n){
        return n.toLocaleString('vi-VN') + " VND";
    }

    // UPDATE
    function updatePrice(){
        let total = packages[currentPackage].total;
        let month = total / currentDuration;
        let day = month / 30;

        document.getElementById("duration").innerText = currentDuration + " THÁNG";
        document.getElementById("total").innerText = format(total);
        document.getElementById("month").innerText = format(Math.round(month));
        document.getElementById("day").innerText = format(Math.round(day));
    }

    updatePrice();

    });

</script>
